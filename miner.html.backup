            <div class="power-stat-value" id="efficiency">--</div>
            <div class="power-stat-label">J/TH</div>
          </div>
          <div class="power-stat">
            <div class="power-stat-value" id="powerCost">$0.00</div>
            <div class="power-stat-label">Cost/Day</div>
          </div>
        </div>
        
        <!-- Stats Grid -->
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-value success" id="hashrateStat">0</div>
            <div class="stat-label">HASH RATE</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="tempStat">--</div>
