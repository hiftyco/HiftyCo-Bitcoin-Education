          </div>
          <div class="stat-card">
            <div class="stat-value" id="fanStat">--</div>
            <div class="stat-label">FAN (RPM)</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="sharesStat">0</div>
            <div class="stat-label">SHARES</div>
