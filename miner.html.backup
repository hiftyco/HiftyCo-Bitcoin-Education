            <div class="heat-sink" id="heatSink">
              <div class="heat-vane"></div><div class="heat-vane"></div><div class="heat-vane"></div>
              <div class="heat-vane"></div><div class="heat-vane"></div><div class="heat-vane"></div>
              <div class="heat-vane"></div><div class="heat-vane"></div><div class="heat-vane"></div>
              <div class="heat-vane"></div><div class="heat-vane"></div><div class="heat-vane"></div>
              <div class="heat-vane"></div><div class="heat-vane"></div><div class="heat-vane"></div>
              <div class="heat-vane"></div>
            </div>
            
            <div class="fan-section">
              <div class="fan-container" id="fan1">
                <div class="fan-housing">
                  <div class="fan-blade"></div>
                  <div class="fan-center"></div>
                </div>
              </div>
              <div class="fan-container" id="fan2">
                <div class="fan-housing">
                  <div class="fan-blade"></div>
                  <div class="fan-center"></div>
                </div>
              </div>
            </div>
            
            <!-- Overclock Panel -->
            <div class="overclock-panel" id="overclockPanel">
              <div class="overclock-header">
                <div class="overclock-title">🚀 OVERCLOCK</div>
                <div class="overclock-value" id="overclockValue">100%</div>
              </div>
              <input type="range" class="overclock-slider" id="overclockSlider" min="100" max="150" value="100" oninput="updateOverclock()">
              <div class="intensity-control">
                <span class="intensity-label">Intensity:</span>
                <div class="intensity-btns">
                  <button class="intensity-btn" onclick="setIntensity(1)">1</button>
                  <button class="intensity-btn" onclick="setIntensity(2)">2</button>
                  <button class="intensity-btn" onclick="setIntensity(3)">3</button>
                  <button class="intensity-btn active" onclick="setIntensity(4)">4</button>
                  <button class="intensity-btn" onclick="setIntensity(5)">5</button>
                </div>
              </div>
              <button class="boost-btn" id="boostBtn" onclick="toggleBoost()" disabled>⚡ Activate Boost</button>
            </div>
            
            <div class="control-panel">
              <div class="power-button-container">
                <button class="power-button" id="powerBtn" onclick="togglePower()">
                  <span class="power-icon">⏻</span>
