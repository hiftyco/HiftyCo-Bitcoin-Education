            <option value="bitcoin.com">stratum.pool.bitcoin.com</option>
            <option value="antpool">antpool.com</option>
            <option value="f2pool">f2pool.com</option>
            <option value="viabtc">viabtc.com</option>
            <option value="slush">slushpool.com</option>
          </select>
          <div style="display: flex; gap: 8px;">
            <input type="text" id="workerName" placeholder="worker1" style="flex:1;padding:10px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.85rem;">
            <input type="text" id="workerPass" placeholder="x" style="width:60px;padding:10px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:0.85rem;text-align:center;">
          </div>
          <button class="btn-apply" onclick="applyPoolConfig()" style="margin-top: 12px;">Apply Configuration</button>
        </div>
        
        <!-- Solo Mode Info -->
        <div class="pool-info" id="soloInfo" style="display: none;">
