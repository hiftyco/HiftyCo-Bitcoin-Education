            </div>
          </div>
          <div class="progress-item">
            <div class="progress-header">
              <span class="progress-label">Fan Speed</span>
              <span class="progress-value" id="fanPercent">--</span>
            </div>
            <div class="progress-bar">
              <div class="progress-fill fan" id="fanBar" style="width: 0%"></div>
            </div>
          </div>
        </div>
        
        <div class="control-buttons">
          <button class="btn-control btn-start" id="startBtn" onclick="startMining()" disabled>
            ▶ Start Mining
          </button>
          <button class="btn-control btn-stop" id="stopBtn" onclick="stopMining()" disabled>
            ⏹ Stop
          </button>
        </div>
        
        <div style="margin-top: 24px;">
          <div class="dashboard-title" style="font-size: 0.9rem;">SYSTEM LOG</div>
          <div class="logs-container" id="logsContainer">
