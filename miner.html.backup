    <!-- Income Section -->
    <div class="income-section">
      <div class="income-header">
        <div class="income-title">⚡ MINING REWARDS</div>
        <div class="income-value" id="totalEarned">₿ 0.00000000</div>
        <div class="income-fiat" id="fiatEarned">$0.00 USD</div>
      </div>
      <div class="income-grid">
        <div class="income-stat">
          <div class="income-stat-value" id="sharesTotal">0</div>
          <div class="income-stat-label">Total Shares</div>
