    <!-- Education Section -->
    <div class="edu-section">
      <h2 class="edu-title">Learn About <span>Bitcoin Mining</span></h2>
      
      <div class="edu-grid">
        <div class="edu-card">
          <div class="edu-icon">🔐</div>
          <h3>What is Mining?</h3>
          <p>Bitcoin mining is the process of adding transaction records to Bitcoin's public ledger. Miners compete to solve complex mathematical puzzles, and the winner gets newly created Bitcoin as a reward.</p>
        </div>
        
        <div class="edu-card">
          <div class="edu-icon">⚡</div>
          <h3>Hash Rate</h3>
          <p>Hash rate measures the miner's computational power. Higher hash rate = more chances to find blocks. The Bitaxe Ultra produces around 450 GH/s (billion hashes per second).</p>
        </div>
        
        <div class="edu-card">
          <div class="edu-icon">🏊</div>
          <h3>Mining Pools</h3>
          <p>Solo mining is extremely difficult. Pools combine many miners' hash power to find blocks more frequently. Rewards are shared proportionally based on each miner's contribution.</p>
        </div>
        
        <div class="edu-card">
          <div class="edu-icon">🎯</div>
          <h3>Proof of Work</h3>
          <p>Bitcoin uses Proof of Work (PoW) consensus. Miners must prove they've expended computational energy. This secures the network and creates new coins fairly.</p>
        </div>
        
        <div class="edu-card">
          <div class="edu-icon">📉</div>
          <h3>Halving</h3>
          <p>Every ~4 years, Bitcoin block rewards halve. In 2024, rewards went from 6.25 to 3.125 BTC. This decreasing supply is what makes Bitcoin deflationary.</p>
        </div>
        
        <div class="edu-card">
          <div class="edu-icon">💰</div>
          <h3>Profitability</h3>
          <p>Mining profit depends on: electricity cost, Bitcoin price, network difficulty, and hashrate. Use the calculator below to estimate your potential earnings.</p>
        </div>
      </div>
    </div>
    
    <div class="calc-section">
      <h3 class="calc-title">⛏️ Mining Profitability Calculator</h3>
      <div class="calc-inputs">
        <div class="calc-input-group">
          <label>Hash Rate (GH/s)</label>
          <input type="number" class="calc-input" id="calcHashrate" value="450">
        </div>
        <div class="calc-input-group">
          <label>Electricity ($/kWh)</label>
          <input type="number" class="calc-input" id="calcPower" value="0.10" step="0.01">
        </div>
        <div class="calc-input-group">
          <label>Power (Watts)</label>
          <input type="number" class="calc-input" id="calcWatts" value="320">
        </div>
        <button class="btn-calc" onclick="calculateProfit()">Calculate</button>
      </div>
      <div class="calc-result" id="calcResult">
        $2.47 / day
        <span>Revenue: $4.32 | Costs: $1.85 | Pool fees: $0.22</span>
      </div>
    </div>
  </div>
  
  <footer class="footer">
    <p>₿ HiftyCo — Interactive Bitcoin Education</p>
    <p style="margin-top: 8px;">Learn Bitcoin by doing. Simulation for educational purposes only.</p>
  </footer>

  <script>
    // ===== ACHIEVEMENTS DATA =====
    const achievements = [
      { id: 'first_share', icon: '📤', name: 'First Share', desc: 'Submit your first share', condition: (s) => s.totalShares >= 1, unlocked: false },
      { id: 'share_100', icon: '📊', name: 'Century Club', desc: 'Submit 100 shares', condition: (s) => s.totalShares >= 100, unlocked: false },
      { id: 'share_1000', icon: '📈', name: 'Hash Master', desc: 'Submit 1,000 shares', condition: (s) => s.totalShares >= 1000, unlocked: false },
      { id: 'first_block', icon: '🔗', name: 'Block Breaker', desc: 'Find your first block', condition: (s) => s.blocksFound >= 1, unlocked: false },
      { id: 'block_10', icon: '🏅', name: 'Block Champion', desc: 'Find 10 blocks', condition: (s) => s.blocksFound >= 10, unlocked: false },
      { id: 'btc_1', icon: '₿', name: 'Millionaire', desc: 'Earn 1 BTC', condition: (s) => s.totalEarned >= 1, unlocked: false },
      { id: 'uptime_1h', icon: '⏱️', name: 'Dedicated Miner', desc: 'Mine for 1 hour', condition: (s) => s.uptimeSeconds >= 3600, unlocked: false },
      { id: 'uptime_24h', icon: '🌙', name: 'Round the Clock', desc: 'Mine for 24 hours', condition: (s) => s.uptimeSeconds >= 86400, unlocked: false },
      { id: 'solo_miner', icon: '⛏️', name: 'Solo Pioneer', desc: 'Try solo mining', condition: (s) => s.soloAttempts >= 1, unlocked: false },
      { id: 'overclock', icon: '🚀', name: 'Speed Demon', desc: 'Use overclock feature', condition: (s) => s.usedOverclock, unlocked: false },
      { id: 'all_asics', icon: '🔧', name: 'ASIC Collector', desc: 'Try all ASIC models', condition: (s) => s ASICsTried >= 4, unlocked: false },
      { id: 'max_streak', icon: '🔥', name: 'On Fire', desc: '10 shares in a row', condition: (s) => s.shareStreak >= 10, unlocked: false }
    ];
    
    // ===== STATE =====
    const asicModels = {
      bitaxe: { name: 'BITAXE', model: 'ULTRA', hashrate: 450, watts: 320, efficiency: 1.4 },
      antminer: { name: 'ANTMINER', model: 'S19', hashrate: 95000, watts: 3250, efficiency: 34 },
      whatsminer: { name: 'WHATSMINER', model: 'M30S+', hashrate: 86000, watts: 3200, efficiency: 37 },
      braiins: { name: 'BRAIINS', model: 'OS+', hashrate: 120000, watts: 2800, efficiency: 23 }
    };
    
    const pools = {
      'bitcoin.com': { name: 'stratum.pool.bitcoin.com', fee: 2 },
      'antpool': { name: 'antpool.com', fee: 2.5 },
      'f2pool': { name: 'f2pool.com', fee: 3 },
      'viabtc': { name: 'viabtc.com', fee: 2 },
      'slush': { name: 'slushpool.com', fee: 2 }
    };
    
    // State
    let isPowered = false;
    let isMining = false;
    let soundEnabled = true;
    let miningMode = 'pool';
    let selectedAsic = 'bitaxe';
    let hashrate = 0;
    let targetHashrate = 450;
    let temperature = 0;
    let fanSpeed = 0;
    let shares = 0;
    let totalShares = 0;
    let totalEarned = 0;
    let btcPrice = 70000;
    let powerCostPerKwh = 0.10;
    let blocksFound = 0;
    let blockHistory = [];
    let uptimeSeconds = 0;
    let uptimeInterval;
    
    // New state
    let currentAsic = asicModels[selectedAsic];
    let overclockPercent = 100;
    let isBoosting = false;
    let intensity = 4;
    let shareStreak = 0;
    let soloAttempts = 0;
    let ASICsTried = new Set([selectedAsic]);
    let usedOverclock = false;
    let hashrateHistory = [];
    let consecutiveShares = 0;
    
    // Graph
    let graphCanvas, graphCtx;
    
    // DOM Elements
    const minerDevice = document.getElementById('minerDevice');
    const displayHashrate = document.getElementById('displayHashrate');
    const displayLabel = document.getElementById('displayLabel');
    const ledPower = document.getElementById('ledPower');
    const ledNetwork = document.getElementById('ledNetwork');
    const ledFan = document.getElementById('ledFan');
    const ledError = document.getElementById('ledError');
    const ledBlock = document.getElementById('ledBlock');
    const fan1 = document.getElementById('fan1');
    const fan2 = document.getElementById('fan2');
    const powerBtn = document.getElementById('powerBtn');
    const startBtn = document.getElementById('startBtn');
    const stopBtn = document.getElementById('stopBtn');
    const logsContainer = document.getElementById('logsContainer');
    
    // ===== INITIALIZATION =====
    function init() {
      selectAsic('bitaxe');
      initGraph();
      renderAchievements();
      calculateProfit();
    }
    
    // ===== GRAPH FUNCTIONS =====
    function initGraph() {
      graphCanvas = document.getElementById('hashrateGraph');
      graphCtx = graphCanvas.getContext('2d');
      resizeGraph();
      window.addEventListener('resize', resizeGraph);
      requestAnimationFrame(drawGraph);
    }
    
    function resizeGraph() {
      const rect = graphCanvas.parentElement.getBoundingClientRect();
      graphCanvas.width = rect.width - 32;
      graphCanvas.height = 80;
    }
    
    function drawGraph() {
      const w = graphCanvas.width;
      const h = graphCanvas.height;
      
      // Clear
      graphCtx.fillStyle = '#080810';
      graphCtx.fillRect(0, 0, w, h);
      
      // Grid lines
      graphCtx.strokeStyle = 'rgba(255,255,255,0.05)';
      graphCtx.lineWidth = 1;
      for (let i = 0; i < 4; i++) {
        const y = (h / 4) * i;
        graphCtx.beginPath();
        graphCtx.moveTo(0, y);
        graphCtx.lineTo(w, y);
        graphCtx.stroke();
      }
      
      // Data line
      if (hashrateHistory.length > 1) {
        const maxHash = currentAsic.hashrate * 1.2;
        
        // Gradient fill
        const gradient = graphCtx.createLinearGradient(0, 0, 0, h);
        gradient.addColorStop(0, 'rgba(0,255,136,0.3)');
        gradient.addColorStop(1, 'rgba(0,255,136,0)');
        
        graphCtx.beginPath();
        graphCtx.moveTo(0, h);
        
        hashrateHistory.forEach((val, i) => {
          const x = (i / (hashrateHistory.length - 1)) * w;
          const y = h - (val / maxHash) * h;
          if (i === 0) {
            graphCtx.lineTo(x, y);
          } else {
            graphCtx.lineTo(x, y);
          }
        });
        
        graphCtx.lineTo(w, h);
        graphCtx.closePath();
        graphCtx.fillStyle = gradient;
        graphCtx.fill();
        
        // Line
        graphCtx.beginPath();
        hashrateHistory.forEach((val, i) => {
          const x = (i / (hashrateHistory.length - 1)) * w;
          const y = h - (val / maxHash) * h;
          if (i === 0) {
            graphCtx.moveTo(x, y);
          } else {
            graphCtx.lineTo(x, y);
          }
        });
        graphCtx.strokeStyle = '#00ff88';
        graphCtx.lineWidth = 2;
        graphCtx.stroke();
      }
      
      requestAnimationFrame(drawGraph);
    }
    
    // ===== ACHIEVEMENTS =====
    function renderAchievements() {
      const grid = document.getElementById('achievementsGrid');
      grid.innerHTML = achievements.map(a => `
        <div class="achievement-badge ${a.unlocked ? 'unlocked' : ''}" id="badge-${a.id}">
          <div class="achievement-badge-icon">${a.icon}</div>
          <div class="achievement-badge-name">${a.name}</div>
          <div class="achievement-badge-desc">${a.desc}</div>
        </div>
      `).join('');
    }
    
    function checkAchievements() {
      const state = {
        totalShares, blocksFound, totalEarned, uptimeSeconds, 
        soloAttempts, usedOverclock, ASICsTried: ASICsTried.size, shareStreak
      };
      
      achievements.forEach(ach => {
        if (!ach.unlocked && ach.condition(state)) {
          ach.unlocked = true;
          showAchievement(ach);
          document.getElementById(`badge-${ach.id}`).classList.add('unlocked');
        }
      });
    }
    
    function showAchievement(ach) {
      const popup = document.getElementById('achievementPopup');
      document.getElementById('achievementIcon').textContent = ach.icon;
      document.getElementById('achievementTitle').textContent = ach.name;
      document.getElementById('achievementDesc').textContent = ach.desc;
      
      popup.classList.add('show');
      playAchievementSound();
      
      setTimeout(() => {
        popup.classList.remove('show');
      }, 4000);
    }
    
    // ===== SOUND SYSTEM =====
    let audioContext = null;
    let fanOscillator = null;
    let fanGain = null;
    
    function initAudio() {
      if (!audioContext) {
        audioContext = new (window.AudioContext || window.webkitAudioContext)();
      }
    }
    
    function playTone(freq, duration, type = 'sine', volume = 0.1) {
      if (!soundEnabled || !audioContext) return;
      
      const osc = audioContext.createOscillator();
      const gain = audioContext.createGain();
      
      osc.connect(gain);
      gain.connect(audioContext.destination);
      
      osc.type = type;
      osc.frequency.setValueAtTime(freq, audioContext.currentTime);
      gain.gain.setValueAtTime(volume, audioContext.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + duration);
      
      osc.start();
      osc.stop(audioContext.currentTime + duration);
    }
    
    function playShareSound() {
      if (!soundEnabled || !audioContext) return;
      playTone(880 + Math.random() * 200, 0.15, 'square', 0.08);
    }
    
    function playBlockSound() {
      if (!soundEnabled || !audioContext) return;
      
      const notes = [523, 659, 784, 1047, 1319];
      notes.forEach((freq, i) => {
        setTimeout(() => playTone(freq, 0.3, 'sine', 0.15), i * 100);
      });
    }
    
    function playPowerOnSound() {
      if (!soundEnabled || !audioContext) return;
      
      // Startup chime
      const notes = [220, 277, 330, 440];
      notes.forEach((freq, i) => {
        setTimeout(() => playTone(freq, 0.4, 'sine', 0.12), i * 150);
      });
    }
    
    function playAchievementSound() {
      if (!soundEnabled || !audioContext) return;
      
      const notes = [523, 659, 784, 1047];
      notes.forEach((freq, i) => {
        setTimeout(() => playTone(freq, 0.2, 'sine', 0.1), i * 80);
      });
    }
    
    function startFanSound() {
      if (!soundEnabled || !audioContext || fanOscillator) return;
      
      fanOscillator = audioContext.createOscillator();
      fanGain = audioContext.createGain();
      
      fanOscillator.connect(fanGain);
      fanGain.connect(audioContext.destination);
      
      fanOscillator.type = 'sawtooth';
      fanOscillator.frequency.setValueAtTime(60 + Math.random() * 40, audioContext.currentTime);
      fanGain.gain.setValueAtTime(0.02, audioContext.currentTime);
      
      fanOscillator.start();
    }
    
    function stopFanSound() {
      if (fanOscillator) {
        fanOscillator.stop();
        fanOscillator = null;
        fanGain = null;
      }
    }
    
    function toggleSound() {
      soundEnabled = !soundEnabled;
      const toggle = document.getElementById('soundToggle');
      
      if (soundEnabled) {
        toggle.classList.add('active');
        toggle.innerHTML = '🔊 Sound On';
        initAudio();
        if (isMining) startFanSound();
      } else {
        toggle.classList.remove('active');
        toggle.innerHTML = '🔇 Sound Off';
        stopFanSound();
      }
    }
    
    // ===== PARTICLES =====
    function createParticle() {
      if (!isMining) return;
      
      const container = document.getElementById('particlesContainer');
      const particle = document.createElement('div');
      particle.className = 'particle';
      
      // Random position
      const x = Math.random() * 100;
      const y = 80 + Math.random() * 20;
      particle.style.left = x + '%';
      particle.style.top = y + '%';
      
      // Color
      const colors = ['#00ff88', '#f7931a', '#ffd700', '#00d4ff'];
      particle.style.background = colors[Math.floor(Math.random() * colors.length)];
      
      container.appendChild(particle);
      
      setTimeout(() => particle.remove(), 2000);
    }
    
    // ===== CONFETTI =====
    function createConfetti() {
      const container = document.getElementById('confettiContainer');
      const colors = ['#f7931a', '#ffd700', '#00ff88', '#ff4757', '#00d4ff'];
      
      for (let i = 0; i < 100; i++) {
        const confetti = document.createElement('div');
        confetti.className = 'confetti';
        confetti.style.left = Math.random() * 100 + '%';
        confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
        confetti.style.animationDelay = Math.random() * 2 + 's';
        confetti.style.animationDuration = (3 + Math.random() * 2) + 's';
        
        if (Math.random() > 0.5) {
          confetti.style.borderRadius = '50%';
        }
        
        container.appendChild(confetti);
        
        setTimeout(() => confetti.remove(), 5000);
      }
    }
    
    // ===== LOGGING =====
    function addLog(message, type = 'info') {
      const time = new Date().toLocaleTimeString('en-US', { hour12: false });
      const logLine = document.createElement('div');
      logLine.className = 'log-line';
      logLine.innerHTML = `<span class="log-time">[${time}]</span> <span class="log-${type}">${message}</span>`;
      logsContainer.appendChild(logLine);
      logsContainer.scrollTop = logsContainer.scrollHeight;
    }
    
    // ===== MODE =====
    function setMode(mode) {
      miningMode = mode;
      
      if (mode === 'solo') {
        soloAttempts++;
        checkAchievements();
      }
      
      document.getElementById('modePool').classList.toggle('active', mode === 'pool');
      document.getElementById('modeSolo').classList.toggle('active', mode === 'solo');
      
      document.getElementById('poolConfigSection').style.display = mode === 'pool' ? 'block' : 'none';
      document.getElementById('poolInfo').style.display = mode === 'pool' ? 'block' : 'none';
      document.getElementById('soloInfo').style.display = mode === 'solo' ? 'block' : 'none';
      document.getElementById('blockHistory').style.display = mode === 'solo' ? 'block' : 'none';
      
      if (isPowered) {
        addLog(mode === 'solo' ? 'Switched to SOLO mining mode' : 'Switched to POOL mining mode', 'warn');
      }
    }
    
    // ===== ASIC SELECTION =====
    function selectAsic(asic) {
      selectedAsic = asic;
      ASICsTried.add(asic);
      currentAsic = asicModels[asic];
      
      document.querySelectorAll('.asic-card').forEach(card => card.classList.remove('selected'));
      document.getElementById('asic-' + asic).classList.add('selected');
      
      document.getElementById('brandName').textContent = currentAsic.name;
      document.getElementById('brandModel').textContent = currentAsic.model;
      
      targetHashrate = currentAsic.hashrate;
      
      document.getElementById('calcHashrate').value = currentAsic.hashrate;
      document.getElementById('calcWatts').value = currentAsic.watts;
      
      document.getElementById('efficiency').textContent = currentAsic.efficiency + ' J/TH';
      document.getElementById('efficiency').className = 'power-stat-value ' + (currentAsic.efficiency < 30 ? 'efficient' : 'inefficient');
      
      calculateProfit();
      checkAchievements();
      
      if (isPowered) {
        addLog(`ASIC changed to ${currentAsic.name} ${currentAsic.model}`, 'warn');
      }
    }
    
    // ===== OVERCLOCK =====
    function updateOverclock() {
      overclockPercent = parseInt(document.getElementById('overclockSlider').value);
      document.getElementById('overclockValue').textContent = overclockPercent + '%';
      
      if (isBoosting) {
        // Apply to hashrate
        targetHashrate = currentAsic.hashrate * (overclockPercent / 100);
      }
    }
    
    function setIntensity(level) {
      intensity = level;
      document.querySelectorAll('.intensity-btn').forEach((btn, i) => {
        btn.classList.toggle('active', i + 1 === level);
      });
      
      if (isMining) {
        // Adjusts share frequency
        const speed = 1 - (level - 1) * 0.15;
        addLog(`Intensity set to ${level}x`, 'info');
      }
    }
    
    function toggleBoost() {
      if (!isPowered || !isMining) return;
      
      isBoosting = !isBoosting;
      const boostBtn = document.getElementById('boostBtn');
      
      usedOverclock = true;
      checkAchievements();
      
      if (isBoosting) {
        boostBtn.classList.add('active');
        boostBtn.textContent = '⚡ BOOST ACTIVE';
        displayHashrate.classList.add('boosting');
        minerDevice.classList.add('mining');
        
        targetHashrate = currentAsic.hashrate * (overclockPercent / 100) * 1.2;
        addLog(`🔥 BOOST ACTIVATED! +${overclockPercent - 100}% power!`, 'warn');
        
        // Temperature skyrockets
        temperature += 15;
        
        playTone(660, 0.3, 'square', 0.1);
      } else {
        boostBtn.classList.remove('active');
        boostBtn.textContent = '⚡ Activate Boost';
        displayHashrate.classList.remove('boosting');
        minerDevice.classList.remove('mining');
        
        targetHashrate = currentAsic.hashrate;
        addLog('Boost deactivated', 'info');
      }
    }
    
    // ===== POOL =====
    function updatePoolInfo() {
      const poolSelect = document.getElementById('poolSelect');
      const pool = pools[poolSelect.value];
      document.getElementById('poolName').textContent = pool.name;
    }
    
    function applyPoolConfig() {
      const workerName = document.getElementById('workerName').value || 'worker1';
      const poolSelect = document.getElementById('poolSelect');
      const pool = pools[poolSelect.value];
      
      addLog(`Pool: ${pool.name}`, 'info');
      addLog(`Worker: ${workerName}`, 'info');
      addLog(`Pool fee: ${pool.fee}%`, 'info');
    }
    
    // ===== POWER =====
    function togglePower() {
      initAudio();
      isPowered = !isPowered;
      
      if (isPowered) {
        minerDevice.classList.remove('Miner_off');
        powerBtn.classList.add('on');
        ledPower.classList.add('on');
        
        // Power up animation
        minerDevice.classList.add('power-up-sequence');
        setTimeout(() => minerDevice.classList.remove('power-up-sequence'), 2000);
        
        playPowerOnSound();
        
        addLog(`Powering on ${currentAsic.name} ${currentAsic.model}...`, 'info');
        
        setTimeout(() => addLog('ASIC chip detected', 'info'), 500);
        setTimeout(() => addLog('Memory test: 512MB OK', 'info'), 1000);
        setTimeout(() => {
          addLog('WiFi connected', 'info');
          ledNetwork.classList.add('on');
          updatePoolStatus(true);
        }, 1500);
        
        setTimeout(() => {
          addLog('Chip calibration complete', 'success');
          displayLabel.textContent = miningMode === 'solo' ? 'TH/S - READY' : 'GH/S - READY';
          startBtn.disabled = false;
          document.getElementById('boostBtn').disabled = false;
          
          if (currentAsic.hashrate >= 1000) {
            displayHashrate.textContent = '0.00';
            displayLabel.textContent = currentAsic.hashrate >= 100000 ? 'TH/S - READY' : 'GH/S - READY';
          }
        }, 2000);
        
      } else {
        stopMining();
        minerDevice.classList.add('Miner_off');
        powerBtn.classList.remove('on');
        ledPower.classList.remove('on');
        ledNetwork.classList.remove('on');
        ledFan.classList.remove('on');
        
        fan1.classList.remove('active');
        fan2.classList.remove('active');
        
        stopFanSound();
        
        displayHashrate.textContent = '0.00';
        displayLabel.textContent = 'GH/S - OFFLINE';
        
        addLog('System shutdown...', 'warn');
        
        document.getElementById('tempStat').textContent = '--';
        document.getElementById('fanStat').textContent = '--';
        document.getElementById('hashrateStat').textContent = '0';
        
        startBtn.disabled = true;
        stopBtn.disabled = true;
        document.getElementById('boostBtn').disabled = true;
        
        updatePoolStatus(false);
      }
    }
    
    function updatePoolStatus(connected) {
      const statusEl = document.getElementById('poolStatus');
      if (connected && miningMode === 'pool') {
        statusEl.className = 'pool-status connected';
        statusEl.innerHTML = '<div class="pool-status-dot"></div><span>Connected</span>';
        document.getElementById('poolWorkers').textContent = '1';
        document.getElementById('poolDiff').textContent = '82.5T';
        document.getElementById('poolPings').textContent = Math.floor(Math.random() * 50 + 20);
      } else if (connected && miningMode === 'solo') {
        statusEl.className = 'pool-status solo';
        statusEl.innerHTML = '<div class="pool-status-dot"></div><span>Mining</span>';
      } else {
        statusEl.className = 'pool-status disconnected';
        statusEl.innerHTML = '<div class="pool-status-dot"></div><span>Disconnected</span>';
        document.getElementById('poolWorkers').textContent = '0';
        document.getElementById('poolDiff').textContent = '--';
        document.getElementById('poolPings').textContent = '--';
      }
    }
    
    // ===== MINING =====
    function startMining() {
      if (!isPowered) return;
      
      initAudio();
      isMining = true;
      shares = 0;
      uptimeSeconds = 0;
      
      startBtn.disabled = true;
      stopBtn.disabled = false;
      
      ledFan.classList.add('on');
      fan1.classList.add('active');
      fan2.classList.add('active');
      
      startFanSound();
      
      minerDevice.classList.add('mining');
      
      // Particle interval
      const particleInterval = setInterval(() => {
        if (!isMining) {
          clearInterval(particleInterval);
          return;
        }
        createParticle();
        createParticle();
      }, 300);
      
      const modeText = miningMode === 'solo' ? 'SOLO' : document.getElementById('poolSelect').value;
      addLog(`Starting ${modeText} mining...`, 'info');
      addLog(`Target hashrate: ${targetHashrate} ${currentAsic.hashrate >= 1000 ? 'GH/s' : 'TH/s'}`, 'info');
      
      displayLabel.textContent = currentAsic.hashrate >= 100000 ? 'TH/S - MINING' : 'GH/S - MINING';
      
      fan1.style.setProperty('--fan-speed', '0.15s');
      fan2.style.setProperty('--fan-speed', '0.15s');
      
      uptimeInterval = setInterval(() => {
        if (isMining) {
          uptimeSeconds++;
          const hours = Math.floor(uptimeSeconds / 3600);
          const mins = Math.floor((uptimeSeconds % 3600) / 60);
          const secs = uptimeSeconds % 60;
          document.getElementById('uptimeStat').textContent = 
            `${hours}:${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
        }
      }, 1000);
      
      // Reset history
      hashrateHistory = new Array(100).fill(0);
      
      simulateMining();
    }
    
    function stopMining() {
      isMining = false;
      startBtn.disabled = false;
      stopBtn.disabled = true;
      
      ledFan.classList.remove('on');
      fan1.classList.remove('active');
      fan2.classList.remove('active');
      ledBlock.classList.remove('on');
      
      minerDevice.classList.remove('mining');
      
      stopFanSound();
      
      addLog('Mining stopped by user', 'warn');
      displayLabel.textContent = currentAsic.hashrate >= 100000 ? 'TH/S - IDLE' : 'GH/S - IDLE';
      
      clearInterval(uptimeInterval);
      checkAchievements();
    }
    
    function simulateMining() {
      const rampUp = setInterval(() => {
        if (!isMining) {
          clearInterval(rampUp);
          return;
        }
        
        const increment = currentAsic.hashrate * 0.03;
        hashrate += increment + (Math.random() * increment * 0.5);
        
        // Apply overclock/boost
        let multiplier = (overclockPercent / 100);
        if (isBoosting) multiplier *= 1.2;
        
        if (hashrate >= currentAsic.hashrate * multiplier) {
          hashrate = currentAsic.hashrate * multiplier * (0.95 + Math.random() * 0.1);
          clearInterval(rampUp);
          
          const unit = currentAsic.hashrate >= 100000 ? 'TH/s' : 'GH/s';
          addLog(`Nominal hashrate achieved: ${formatHashrate(hashrate)} ${unit}`, 'success');
        }
        
        updateDisplay();
        updateGraph();
      }, 200);
      
      const statsInterval = setInterval(() => {
        if (!isMining) {
          clearInterval(statsInterval);
          return;
        }
        
        // Temperature 
        const tempTarget = isBoosting ? 85 + Math.random() * 10 : 55 + Math.random() * 20;
        temperature += (tempTarget - temperature) * 0.1;
        
        updateHeatSink();
        
        // Fan based on temp
        fanSpeed = Math.min(6500, 2000 + (temperature * 55));
        
        // Hashrate fluctuation
        let fluctuation = isBoosting ? 0.08 : 0.04;
        hashrate = Math.max(currentAsic.hashrate * 0.7, Math.min(currentAsic.hashrate * 1.3, 
          hashrate + (hashrate * (Math.random() * fluctuation - fluctuation/2))));
        
        if (isBoosting) {
          hashrate *= (overclockPercent / 100);
        }
        
        // Share finding - intensity affects frequency
        const shareChance = 0.15 + (intensity - 1) * 0.05;
        if (Math.random() < shareChance) {
          shares++;
          totalShares++;
          consecutiveShares++;
          shareStreak = Math.max(shareStreak, consecutiveShares);
          
          const diff = (Math.random() * 1000 + 100).toFixed(0);
          addLog(`Share accepted! (diff: ${diff})`, 'hash');
          
          playShareSound();
          
          const sharesStat = document.getElementById('sharesStat').parentElement;
          sharesStat.classList.add('share-found');
          setTimeout(() => sharesStat.classList.remove('share-found'), 500);
          
          if (miningMode === 'pool') {
            const shareValue = 0.000001 * (hashrate / currentAsic.hashrate);
            totalEarned += shareValue;
            document.body.classList.add('screen-shake');
            setTimeout(() => document.body.classList.remove('screen-shake'), 500);
          }
          
          checkAchievements();
        } else {
          consecutiveShares = 0;
        }
        
        // Solo mode - block finding
        if (miningMode === 'solo') {
          const blockProbability = (hashrate / 180000000000000) * 100 * intensity;
          
          if (Math.random() < blockProbability * 5) { // Demo boost
            foundBlock();
          }
        }
        
        // Temperature warnings
        if (temperature > 80) {
          addLog(`⚠️ Temperature critical: ${temperature.toFixed(0)}°C`, 'error');
          ledError.classList.add('on');
          setTimeout(() => ledError.classList.remove('on'), 2000);
          
          // Auto throttle
          if (isBoosting && temperature > 90) {
            addLog('Auto-throttling due to heat!', 'error');
            toggleBoost();
          }
        } else if (temperature > 70) {
          addLog(`⚠️ Temperature high: ${temperature.toFixed(0)}°C`, 'warn');
        }
        
        updateDisplay();
        updateEarnings();
        updatePowerStats();
        updateGraph();
      }, 1000);
    }
    
    function foundBlock() {
      blocksFound++;
      const reward = 3.125;
      totalEarned += reward;
      blockHistory.push({ height: 876000 + blocksFound, reward: reward });
      
      addLog(`🎉 BLOCK FOUND! Height: 876${blocksFound.toString().padStart(3, '0')} Reward: ${reward} BTC`, 'block');
      
      // Notification
      const notification = document.getElementById('blockNotification');
      notification.classList.add('show');
      playBlockSound();
      createConfetti();
      
      setTimeout(() => notification.classList.remove('show'), 4000);
      
      // LED
      ledBlock.classList.add('on');
      setTimeout(() => ledBlock.classList.remove('on'), 3000);
      
      // Screen shake
      document.body.classList.add('screen-shake');
      setTimeout(() => document.body.classList.remove('screen-shake'), 500);
      
      // Block history
      if (blockHistory.length <= 10) {
        const grid = document.getElementById('blocksGrid');
        const chip = document.createElement('div');
        chip.className = 'block-chip';
        chip.innerHTML = `
          <div class="block-chip-value">#876${blocksFound.toString().padStart(3, '0')}</div>
          <div class="block-chip-reward">+₿ ${reward}</div>
        `;
        grid.insertBefore(chip, grid.firstChild);
      }
      
      document.getElementById('blocksFound').textContent = blocksFound;
      checkAchievements();
    }
    
    function updateGraph() {
      hashrateHistory.push(hashrate);
      if (hashrateHistory.length > 100) {
        hashrateHistory.shift();
      }
    }
    
    function updateHeatSink() {
      const vanes = document.querySelectorAll('.heat-vane');
      vanes.forEach((vane, i) => {
        vane.classList.remove('hot', 'critical');
        
        const threshold = 30 + (i * 5);
        
        if (temperature > 80) {
          vane.classList.add('critical');
        } else if (temperature > threshold) {
          vane.classList.add('hot');
        }
      });
    }
    
    function formatHashrate(hash) {
      if (hash >= 1000000) return (hash / 1000000).toFixed(2);
      if (hash >= 1000) return (hash / 1000).toFixed(2);
      return hash.toFixed(2);
    }
    
    function formatHashrateUnit(hash) {
      if (hash >= 1000000) return 'PH/s';
      if (hash >= 1000) return 'TH/s';
      return 'GH/s';
    }
    
    function updateDisplay() {
      displayHashrate.textContent = formatHashrate(hashrate);
      
      const unit = formatHashrateUnit(currentAsic.hashrate);
      document.getElementById('hashrateStat').textContent = formatHashrate(hashrate);
      document.querySelector('#hashrateStat').nextElementSibling.textContent = `HASH RATE (${unit.replace('/s', '')})`;
      
      document.getElementById('tempStat').textContent = temperature.toFixed(0);
      document.getElementById('fanStat').textContent = Math.floor(fanSpeed);
      document.getElementById('sharesStat').textContent = shares;
      
      // Progress bars
      const hashratePercent = Math.min(100, (hashrate / (currentAsic.hashrate * (overclockPercent/100))) * 100);
      document.getElementById('hashratePercent').textContent = Math.round(hashratePercent) + '%';
      document.getElementById('hashrateBar').style.width = hashratePercent + '%';
      
      const tempPercent = Math.min(100, (temperature / 95) * 100);
      document.getElementById('tempPercent').textContent = temperature.toFixed(0) + '°C';
      document.getElementById('tempBar').style.width = tempPercent + '%';
      
      const fanPercent = Math.min(100, (fanSpeed / 6500) * 100);
      document.getElementById('fanPercent').textContent = Math.floor(fanSpeed) + ' RPM';
      document.getElementById('fanBar').style.width = fanPercent + '%';
      
      // Temperature color
      const tempStat = document.getElementById('tempStat');
      if (temperature > 75) {
        tempStat.className = 'stat-value danger';
      } else if (temperature > 60) {
        tempStat.className = 'stat-value warning';
      } else {
        tempStat.className = 'stat-value success';
      }
    }
    
    function updateEarnings() {
      document.getElementById('totalEarned').textContent = '₿ ' + totalEarned.toFixed(8);
      document.getElementById('fiatEarned').textContent = '$' + (totalEarned * btcPrice).toFixed(2) + ' USD';
      document.getElementById('sharesTotal').textContent = totalShares;
      document.getElementById('avgHashrate').textContent = formatHashrate(hashrate);
      document.getElementById('luckStat').textContent = Math.floor(Math.random() * 30 + 85) + '%';
      
      if (miningMode === 'pool') {
        const dailyRevenue = (hashrate / currentAsic.hashrate) * 4.32;
        document.getElementById('estDaily').textContent = '$' + dailyRevenue.toFixed(2);
      } else {
        const avgBlockTime = 600000;
        const blocksPerDay = 86400 / (avgBlockTime / (hashrate / 180000000000000));
        const expectedRevenue = blocksPerDay * 3.125 * btcPrice;
        document.getElementById('estDaily').textContent = '$' + expectedRevenue.toFixed(2) + ' (expected)';
      }
    }
    
    function updatePowerStats() {
      let powerDraw = currentAsic.watts * (hashrate / currentAsic.hashrate);
      
      if (isBoosting) {
        powerDraw *= 1.2;
      }
      
      document.getElementById('powerDraw').textContent = Math.round(powerDraw) + 'W';
      
      const powerCostPerDay = (powerDraw / 1000) * 24 * powerCostPerKwh;
      document.getElementById('powerCost').textContent = '$' + powerCostPerDay.toFixed(2);
    }
    
    function calculateProfit() {
      const hashrate = parseFloat(document.getElementById('calcHashrate').value);
      const powerCost = parseFloat(document.getElementById('calcPower').value);
      const watts = parseFloat(document.getElementById('calcWatts').value);
      
      powerCostPerKwh = powerCost;
      
      const networkHashrate = 180000000000000;
      const btcPerDay = 900 / (networkHashrate / hashrate * 600);
      
      const revenue = btcPerDay * btcPrice;
      const powerPerDay = (watts / 1000) * 24 * powerCost;
      const poolFee = miningMode === 'pool' ? revenue * 0.02 : 0;
      const profit = revenue - powerPerDay - poolFee;
      
      const result = document.getElementById('calcResult');
      
      if (miningMode === 'solo') {
        result.innerHTML = `$${profit.toFixed(2)} / day
          <span>Expected: ${btcPerDay.toFixed(6)} BTC/day | Costs: $${powerPerDay.toFixed(2)}</span>`;
      } else {
        result.innerHTML = `$${profit.toFixed(2)} / day
          <span>Revenue: $${revenue.toFixed(2)} | Costs: $${powerPerDay.toFixed(2)} | Pool fees: $${poolFee.toFixed(2)}</span>`;
      }
      
      result.classList.toggle('negative', profit < 0);
      result.style.color = profit > 0 ? 'var(--success)' : 'var(--danger)';
    }
    
    // Start
    init();
  </script>
</body>
</html>