        </div>
        
        <div class="progress-section">
          <div class="progress-item">
            <div class="progress-header">
              <span class="progress-label">Hashrate</span>
              <span class="progress-value" id="hashratePercent">0%</span>
            </div>
            <div class="progress-bar">
              <div class="progress-fill hashrate" id="hashrateBar" style="width: 0%"></div>
            </div>
          </div>
          <div class="progress-item">
