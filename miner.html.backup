            ⛏️ You're mining directly for block rewards! Each block found earns you the full <strong>3.125 BTC</strong> reward. Higher risk, higher reward!
          </p>
        </div>
        
        <!-- Pool Info -->
        <div class="pool-info" id="poolInfo">
          <div class="pool-header">
            <div class="pool-name" id="poolName">stratum.pool.bitcoin.com</div>
            <div class="pool-status disconnected" id="poolStatus">
              <div class="pool-status-dot"></div>
              <span>Disconnected</span>
            </div>
          </div>
          <div class="pool-stats">
            <div class="pool-stat">
              <div class="pool-stat-value" id="poolWorkers">0</div>
              <div class="pool-stat-label">Workers</div>
            </div>
            <div class="pool-stat">
              <div class="pool-stat-value" id="poolDiff">--</div>
              <div class="pool-stat-label">Difficulty</div>
            </div>
            <div class="pool-stat">
              <div class="pool-stat-value" id="poolPings">--</div>
              <div class="pool-stat-label">Ping (ms)</div>
            </div>
          </div>
        </div>
        
        <!-- Power Stats -->
        <div class="power-stats">
          <div class="power-stat">
            <div class="power-stat-value" id="powerDraw">0W</div>
            <div class="power-stat-label">Power Draw</div>
          </div>
